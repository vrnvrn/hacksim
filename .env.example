# Local secrets for HackSim. Copy this file to `.env` (gitignored) and
# fill in the values you want exported when `make demo` or `make smoke`
# runs. Anything in `.env` overrides values that are already in the
# shell environment.
#
# To use: `cp .env.example .env` and edit `.env`.

# Anthropic API key. With a key set, every agent decision and every
# project HTML upgrades to a Claude haiku 4.5 call. Without one, the
# deterministic stub still produces real, distinct output.
ANTHROPIC_API_KEY=

# Optional: pin a specific Claude model id. Defaults to
# `claude-haiku-4-5-20251001` (see packages/agents/_anthropic.py).
# HACKSIM_MODEL=

# Optional: simulation pacing. One of: smoke, quick, medium, deep.
# Defaults to quick (~110 seconds end to end). With real Claude calls
# we recommend `medium` or `deep` so 8 KB compose_project responses
# have time to finish before the JUDGING phase opens.
# HACKSIM_PACE=medium

# Mock-mode default. Flip to false when the FastAPI orchestrator is live and
# the frontend should hit it directly. Mock mode replays the fixtures under
# apps/web/lib/mocks/ and serves the three demo projects under
# apps/web/lib/mocks/projects/.
NEXT_PUBLIC_USE_MOCKS=true

# Where the orchestrator listens. Only used when NEXT_PUBLIC_USE_MOCKS=false.
ORCHESTRATOR_BASE_URL=http://127.0.0.1:8000

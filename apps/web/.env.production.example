# Vercel production environment example.
#
# The committed apps/web/.env.production sets the Mode V1 defaults (mocks on,
# orchestrator URL empty, hosted-preview banner on). For a Mode V2 deploy
# (frontend on Vercel, orchestrator on Fly.io / Railway / a single VM) point
# the frontend at the hosted backend by setting these in the Vercel project
# env vars (Settings -> Environment Variables -> Production):

NEXT_PUBLIC_USE_MOCKS=false
ORCHESTRATOR_BASE_URL=https://hacksim-orchestrator.fly.dev
NEXT_PUBLIC_HOSTED_PREVIEW=true

# Anthropic key. Optional. Live LLM calls fire from the orchestrator process,
# not the frontend, so this is set on the orchestrator host (Fly.io secret
# or whatever the platform calls it), not on Vercel. Listed here for
# completeness so a fork knows where the key lives.
# ANTHROPIC_API_KEY=
